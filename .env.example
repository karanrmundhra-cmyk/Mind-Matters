# ─────────────────────────────────────────────────────────────────────────────
# Personal OS — environment template.  Copy to .env.local and fill in.
# NOTHING here is committed. Real secrets live only in .env.local / the host.
# See KEYS_NEEDED.md for how to obtain each value.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Database (Supabase / Postgres) ─ Step 1 ──────────────────────────────────
# Pooled connection for the app, direct connection for migrations.
DATABASE_URL=""
DIRECT_URL=""

# ── Supabase Auth (Google OAuth) ─ Step 7 ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── AI provider (swappable model-abstraction layer) ─ Step 2 ─────────────────
AI_PROVIDER="anthropic"                      # "anthropic" | "gemini"
# Anthropic:
ANTHROPIC_API_KEY=""
AI_MODEL_FAST="claude-haiku-4-5-20251001"   # parse / classify / extract
AI_MODEL_STRONG="claude-sonnet-4-6"          # drafting / ambiguous inputs
# Gemini (alternative):
GEMINI_API_KEY=""
GEMINI_MODEL_FAST="gemini-2.0-flash"
GEMINI_MODEL_STRONG="gemini-2.0-flash"
AI_MONTHLY_BUDGET_USD="25"                   # per-user soft/hard cap guardrail

# ── Email (Resend) ─ Step 4/7 ────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Personal OS <noreply@yourdomain.com>"

# ── Payments: Razorpay (India) ─ Step 8 ──────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── Payments: Stripe (international) ─ Step 8 ─────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Observability ─ Step 10 ──────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
SENTRY_DSN=""

# Secret used to sign internal job / cron requests
CRON_SECRET=""
